{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude MCP",
  "version": "0.1.4",
  "identifier": "com.zoe.cclaude-mcp",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": true,
        "title": "Claude MCP",
        "width": 520,
        "height": 700,
        "minWidth": 480,
        "minHeight": 660,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
